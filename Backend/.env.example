PORT=3001
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# AI Features — at least one key enables AI summaries, hints, question generation
# Groq (recommended — no billing required, 14,400 req/day free)
# Sign up at https://console.groq.com
GROQ_API_KEY=

# Google Gemini (alternative — use a project WITHOUT billing enabled)
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=